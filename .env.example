# ══════════════════════════════════════════════════════════
#  TripSense AI Travel Recommender — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════

# ── OpenWeatherMap ─────────────────────────────────────────
# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Mistral AI ─────────────────────────────────────────────
# Sign up and get your key at: https://console.mistral.ai/
# Without this key, the app uses a smart rule-based fallback itinerary.
MISTRAL_API_KEY=your_mistral_api_key_here

# ── RapidAPI — Booking.com Hotel Search ───────────────────
# Subscribe at: https://rapidapi.com/booking-com/api/booking-com
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=booking-com.p.rapidapi.com
RAPIDAPI_BASE_URL=https://booking-com.p.rapidapi.com/v1

# ── Flask ─────────────────────────────────────────────────
# Use a long random string in production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
FLASK_DEBUG=false
FLASK_PORT=5000

# ── Logging ───────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── API Caching (seconds, 0 = disabled) ───────────────────
CACHE_TTL_WEATHER=600    # 10 minutes
CACHE_TTL_HOTELS=1800    # 30 minutes
